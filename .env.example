# .env.example — Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.

# ─────────────────────────────────────────────
# CUENTA FTMO
# ─────────────────────────────────────────────
FTMO_ACCOUNT_SIZE=10000         # Tamaño de la cuenta en USD

# ─────────────────────────────────────────────
# TELEGRAM (notificaciones en tiempo real)
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIJKlmNoPQRsTUVwxYz
TELEGRAM_CHAT_ID=-1001234567890

# ─────────────────────────────────────────────
# METAQUOTES / MT5
# ─────────────────────────────────────────────
# MT5 no requiere credenciales adicionales si el terminal ya está logueado.
# Si necesitas login programático, descomenta las siguientes líneas:
# MT5_LOGIN=12345678
# MT5_PASSWORD=tupassword
# MT5_SERVER=ICMarketsEU-Demo
