# FTMO Scalper — Variables de entorno
# Copiar a .env y rellenar con tus valores reales

# --- MT5 (FTMO demo / real) ---
# File > Login to Trade Account en MT5. El servidor suele ser "FTMO-Demo2" o "FTMO-Server2"
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
# Opcional: ruta completa a terminal64.exe si tienes varias instalaciones de MT5
MT5_PATH=

# --- Telegram (notificaciones opcionales) ---
# Crear bot con @BotFather → token
# Obtener chat_id: /start al bot, luego https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
