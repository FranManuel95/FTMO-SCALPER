# Trading Research Lab — Environment Variables
# Copiar a .env y rellenar valores reales

# --- Datos de mercado ---
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENVIRONMENT=practice  # practice | live

ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=

# --- Crypto ---
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- QuantConnect / LEAN ---
QC_USER_ID=
QC_API_TOKEN=
LEAN_WORKSPACE=./lean

# --- Freqtrade ---
FT_USER_DATA_DIR=./freqtrade/user_data
FT_BOT_NAME=research-lab

# --- Base de datos local ---
DATA_DIR=./data
RAW_DIR=./data/raw
PROCESSED_DIR=./data/processed

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=./logs

# --- Entorno ---
ENVIRONMENT=development  # development | production
